{
  "name": "wiedisync",
  "private": true,
  "version": "4.8.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:prod": "VITE_PROD_DATA=1 vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "schema:pull": "node directus/scripts/schema-pull.mjs",
    "schema:diff": "node directus/scripts/schema-diff.mjs",
    "schema:push": "node directus/scripts/schema-push.mjs",
    "db:migrate:dev": "node directus/scripts/apply-migrations.mjs dev",
    "db:migrate:prod": "node directus/scripts/apply-migrations.mjs prod",
    "db:migrate:status:dev": "node directus/scripts/apply-migrations.mjs dev --status",
    "db:migrate:status:prod": "node directus/scripts/apply-migrations.mjs prod --status",
    "db:setup-perms:dev": "DIRECTUS_URL=https://directus-dev.kscw.ch node directus/scripts/setup-permissions.mjs",
    "db:setup-perms:prod": "DIRECTUS_URL=https://directus.kscw.ch node directus/scripts/setup-permissions.mjs",
    "db:smoke:dev": "SMOKE_TEST_URL=https://directus-dev.kscw.ch node directus/scripts/smoke-test.mjs",
    "db:smoke:prod": "SMOKE_TEST_URL=https://directus.kscw.ch node directus/scripts/smoke-test.mjs",
    "db:deploy:dev": "npm run db:migrate:dev && npm run db:setup-perms:dev && npm run db:smoke:dev",
    "db:deploy:prod": "npm run db:migrate:prod && npm run db:setup-perms:prod && npm run db:smoke:prod",
    "db:baseline:dev": "node directus/scripts/regenerate-baseline.mjs dev",
    "db:baseline:prod": "node directus/scripts/regenerate-baseline.mjs prod",
    "db:fresh-install:dev": "cat directus/scripts/SCHEMA.sql | ssh hetzner 'sudo docker exec -i supabase-db-vek42jyj0owoutoouq29aisq psql -U supabase_admin -d directus_kscw_dev -X -v ON_ERROR_STOP=1' && npm run db:migrate:dev && npm run db:setup-perms:dev && npm run db:smoke:dev",
    "db:fresh-install:prod": "cat directus/scripts/SCHEMA.sql | ssh hetzner 'sudo docker exec -i supabase-db-vek42jyj0owoutoouq29aisq psql -U supabase_admin -d postgres -X -v ON_ERROR_STOP=1' && npm run db:migrate:prod && npm run db:setup-perms:prod && npm run db:smoke:prod",
    "ext:deploy:dev": "rsync -avz --delete directus/extensions/ hetzner:/tmp/kscw-extensions/ && ssh hetzner \"sudo rsync -a --delete /tmp/kscw-extensions/ /opt/directus-kscw-dev/extensions/ && sudo docker restart directus-kscw-dev\"",
    "ext:deploy:prod": "rsync -avz --delete directus/extensions/ hetzner:/tmp/kscw-extensions/ && ssh hetzner \"sudo rsync -a --delete /tmp/kscw-extensions/ /opt/directus-kscw/extensions/ && sudo docker restart directus-kscw\"",
    "ext:deploy": "npm run ext:deploy:dev && npm run ext:deploy:prod"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@directus/sdk": "^21.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.51.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.9",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@toon-format/toon": "^2.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "i18next": "^26.0.8",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.6",
    "react-joyride": "^3.1.0",
    "react-router-dom": "^7.15.0",
    "read-excel-file": "^9.0.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.2.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
