<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body style="margin:0;padding:0;background:#0f172a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#0f172a;padding:24px 0">
    <tr>
      <td align="center">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width:480px;background:#1e293b;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.3)">
          <!-- Accent stripe (brand gold) -->
          <tr><td style="background:#FFC832;height:4px;font-size:0;line-height:0">&nbsp;</td></tr>

          <!-- Header with logo -->
          <tr>
            <td style="background:#1e293b;padding:28px 28px 20px;text-align:center">
              <img src="https://wiedisync.kscw.ch/wiedisync_logo.svg" alt="KSC Wiedikon" width="48" height="52" style="width:48px;height:52px">
              <div style="font-size:22px;font-weight:700;color:#ffffff;margin-top:8px">Einladung</div>
              <div style="font-size:14px;color:#94a3b8;margin-top:4px">WiediSync — KSC Wiedikon</div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:4px 28px 20px">
              <div style="font-size:15px;color:#e2e8f0;margin-bottom:12px">
                Hallo,
              </div>
              <div style="font-size:14px;color:#e2e8f0;margin-bottom:16px">
                Du wurdest eingeladen, WiediSync beizutreten — die Plattform des KSC Wiedikon. Klicke auf den Button unten, um dein Konto zu erstellen.
              </div>

              <!-- Info card -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#0f172a;border:1px solid #334155;border-radius:8px;overflow:hidden;margin-bottom:16px">
                <tr>
                  <td style="padding:16px 20px">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding:0 0 10px">
                          <div style="font-size:11px;text-transform:uppercase;color:#64748b;letter-spacing:0.5px;margin-bottom:2px">Plattform</div>
                          <div style="font-size:14px;font-weight:600;color:#e2e8f0">WiediSync — Volleyball &amp; Basketball</div>
                        </td>
                      </tr>
                      <tr>
                        <td>
                          <div style="font-size:11px;text-transform:uppercase;color:#64748b;letter-spacing:0.5px;margin-bottom:2px">Verein</div>
                          <div style="font-size:14px;font-weight:600;color:#e2e8f0">KSC Wiedikon</div>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- CTA button -->
          <tr>
            <td style="padding:0 28px 20px">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding:4px 0 8px">
                    <a href="{{ url }}" style="display:inline-block;background:#FFC832;color:#000000;font-size:14px;font-weight:600;padding:12px 28px;border-radius:8px;text-decoration:none;letter-spacing:0.2px">
                      Konto erstellen
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Fallback URL -->
          <tr>
            <td style="padding:0 28px 20px;text-align:center">
              <div style="font-size:12px;color:#64748b">
                Button funktioniert nicht? Kopiere diesen Link:<br>
                <a href="{{ url }}" style="color:#60a5fa;text-decoration:none;word-break:break-all;font-size:11px">{{ url }}</a>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#0f172a;border-top:1px solid #334155;padding:14px 28px;text-align:center">
              <div style="font-size:11px;color:#64748b">KSC Wiedikon &middot; <a href="https://wiedisync.kscw.ch" style="color:#64748b;text-decoration:none">wiedisync.kscw.ch</a></div>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
