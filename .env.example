VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Enables the messaging feature (chat + DMs + reactions). Defaults to false.
# Set to the literal string "true" to enable. Any other value = disabled.
# Plans 02–05 roll this out behind the flag; Plan 06 flips to true in prod.
VITE_FEATURE_MESSAGING=false
