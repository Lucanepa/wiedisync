####################################
# KSCW Directus — Environment Config
####################################

# Database
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=directus_kscw
DB_USER=directus
DB_PASSWORD=CHANGE_ME

# Security — generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Admin account (created on bootstrap)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME

# Server
HOST=0.0.0.0
PORT=8055
PUBLIC_URL=http://localhost:8055

# File storage (local for dev)
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads

# WebSocket (realtime)
WEBSOCKETS_ENABLED=true

# CORS (allow React dev server)
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Cloudflare Turnstile CAPTCHA (required for production)
TURNSTILE_SECRET=

# Google OAuth SSO (optional)
# AUTH_GOOGLE_DRIVER=openid
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_ISSUER_URL=https://accounts.google.com/.well-known/openid-configuration
# AUTH_GOOGLE_IDENTIFIER_KEY=email
# AUTH_GOOGLE_REDIRECT_ALLOW_LIST=http://localhost:5173/auth/callback

# Email (SMTP)
# EMAIL_TRANSPORT=smtp
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com

# Sentry (optional)
# SENTRY_DSN=

# Cron sync auth (SV / BP / VM sync jobs authenticate per-run via /auth/login
# instead of a static admin token — Directus can silently invalidate static
# tokens on role/schema changes, causing sync crons to 401 unnoticed).
# Use a dedicated service user with Administrator role.
DIRECTUS_SYNC_EMAIL=
DIRECTUS_SYNC_PASSWORD=
